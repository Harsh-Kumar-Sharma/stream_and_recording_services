


MEDIA_SERVICE_CONFIG=config/config.yaml
MEDIA_SERVICE__APP__ENVIRONMENT=development
MEDIA_SERVICE__APP__LOG_LEVEL=INFO

# Use mock Java in Docker. For local Python outside Docker, use http://localhost:8081.
MEDIA_SERVICE__JAVA_API__BASE_URL=http://192.168.0.101:8080

# Python-to-MediaMTX API URL. Use http://localhost:9997 when Python runs on Windows.
MEDIA_SERVICE__MEDIAMTX__BASE_URL=http://localhost:9997

# Browser-facing playback URLs. Replace 192.168.0.103 with your Windows LAN IP
# when React runs on another machine.
MEDIA_SERVICE__MEDIAMTX__PUBLIC_HLS_BASE_URL=http://192.168.0.103:8888
MEDIA_SERVICE__MEDIAMTX__PUBLIC_WEBRTC_BASE_URL=http://192.168.0.103:8889

# Keep recording off on small machines until live stream is verified.
MEDIA_SERVICE__RECORDING__ENABLED=false
MEDIA_SERVICE__RECORDING__STORAGE_ROOT=./storage/recordings
MEDIA_SERVICE__RECORDING__FFMPEG_PATH=ffmpeg
MEDIA_SERVICE__RECORDING__SEGMENT_DURATION_SECONDS=30
MEDIA_SERVICE__RECORDING__MAX_RESTART_ATTEMPTS=1
MEDIA_SERVICE__RECORDING__RESTART_DELAY_SECONDS=3

# Small-machine limits.
MEDIA_SERVICE__WORKER__MAX_LIVE_STREAMS=2
MEDIA_SERVICE__WORKER__MAX_RECORDING_WORKERS=1
MEDIA_SERVICE__WORKER__INACTIVE_STREAM_TTL_SECONDS=60

MEDIA_SERVICE__SECURITY__CORS_ALLOWED_ORIGINS=["*"]
