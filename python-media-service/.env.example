MEDIA_SERVICE_CONFIG=config/config.yaml
MEDIA_SERVICE__APP__ENVIRONMENT=development
MEDIA_SERVICE__APP__LOG_LEVEL=INFO
MEDIA_SERVICE__JAVA_API__BASE_URL=http://java-api-server:8080
MEDIA_SERVICE__MEDIAMTX__BASE_URL=http://localhost:9997
MEDIA_SERVICE__MEDIAMTX__PUBLIC_HLS_BASE_URL=http://localhost:8888
MEDIA_SERVICE__MEDIAMTX__PUBLIC_WEBRTC_BASE_URL=http://localhost:8889
# For LAN frontend testing, use the media server IP instead:
# MEDIA_SERVICE__MEDIAMTX__BASE_URL=http://192.168.0.103:9997
# MEDIA_SERVICE__MEDIAMTX__PUBLIC_HLS_BASE_URL=http://192.168.0.103:8888
MEDIA_SERVICE__RECORDING__ENABLED=true
MEDIA_SERVICE__RECORDING__STORAGE_ROOT=./storage/recordings
MEDIA_SERVICE__RECORDING__FFMPEG_PATH=ffmpeg
MEDIA_SERVICE__SECURITY__CORS_ALLOWED_ORIGINS=["*"]
