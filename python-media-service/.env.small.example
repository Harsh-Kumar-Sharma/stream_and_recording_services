MEDIA_SERVICE_CONFIG=config/config.yaml
MEDIA_SERVICE__APP__ENVIRONMENT=development
MEDIA_SERVICE__APP__LOG_LEVEL=INFO

# Docker mock Java. For local Python outside Docker, use http://localhost:8081.
MEDIA_SERVICE__JAVA_API__BASE_URL=http://mock-java:8080

# Python-to-MediaMTX API. For local Python outside Docker, use http://localhost:9997.
MEDIA_SERVICE__MEDIAMTX__BASE_URL=http://mediamtx:9997

# Browser-facing playback URLs. Replace localhost with the Windows LAN IP when React runs on another machine.
MEDIA_SERVICE__MEDIAMTX__PUBLIC_HLS_BASE_URL=http://localhost:8888
MEDIA_SERVICE__MEDIAMTX__PUBLIC_WEBRTC_BASE_URL=http://localhost:8889

MEDIA_SERVICE__RECORDING__ENABLED=false
MEDIA_SERVICE__RECORDING__STORAGE_ROOT=/data/recordings
MEDIA_SERVICE__RECORDING__FFMPEG_PATH=/usr/bin/ffmpeg
MEDIA_SERVICE__RECORDING__SEGMENT_DURATION_SECONDS=30
MEDIA_SERVICE__RECORDING__MAX_RESTART_ATTEMPTS=1
MEDIA_SERVICE__RECORDING__RESTART_DELAY_SECONDS=3

MEDIA_SERVICE__WORKER__MAX_LIVE_STREAMS=2
MEDIA_SERVICE__WORKER__MAX_RECORDING_WORKERS=1
MEDIA_SERVICE__WORKER__INACTIVE_STREAM_TTL_SECONDS=60

MEDIA_SERVICE__SECURITY__CORS_ALLOWED_ORIGINS=["*"]
